# Wallshoot environment template — copy to .env and fill in values.

# Mailer (~/services/mailer/) — for sending account activation emails
MAILER_URL=http://172.17.0.1:8097
MAILER_API_KEY=

# Session signing — generate with: openssl rand -hex 32
SESSION_SECRET=

# Comma-separated admin emails — get a "管理后台" menu entry after login
ADMIN_EMAILS=
